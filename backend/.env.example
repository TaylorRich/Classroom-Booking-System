# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/classroom_booking

# JWT secret key (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Superadmin credentials
SUPERADMIN_USER=superadmin
SUPERADMIN_PASS=superadmin123

# Server port (optional, defaults to 3000)
PORT=3000

# Google OAuth credentials (optional, only needed if using Google authentication)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
