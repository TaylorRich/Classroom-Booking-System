# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/classroom_booking

# JWT secret key (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Superadmin credentials
SUPERADMIN_USER=superadmin
SUPERADMIN_PASS=superadmin123

# Superadmin TOTP secret — leave blank on first run; after first login the server
# will display the secret in the confirm-2fa-setup response. Copy it here and restart.
SUPERADMIN_TOTP_SECRET=

# App name shown in Google Authenticator
APP_NAME=ClassroomBooking

# Server port (optional, defaults to 3000)
PORT=3000